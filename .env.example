# Example environment for tai42-skeleton. Copy to `.env` and fill in.
# Only variable NAMES + placeholders are shown; never commit a real `.env`.
# Each settings group has more knobs than listed here — these are the common ones.

# --- Runtime / config location ----------------------------------------------
# CONFIG_DIR_PATH=./app                 # dir holding manifest.yml + .env (default: /app)
# TAI_MANIFEST_PATH=./manifest.yml      # default for the CLI's --manifest-path flag
#                                       # (the flag itself always wins)
# TAI_TRANSPORT=http                    # http (default) | sse | stdio

# --- Connector engine secrets (base64 of 32 random bytes) -------------------
# Generate each: python -c 'import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())'
CONNECTORS_KEK=
CONNECTORS_STATE_HMAC_KEY=
# CONNECTORS_REDIRECT_URI_ALLOWLIST=   # comma/JSON list of allowed OAuth redirect URIs

# --- Connector token store (Redis cache + Postgres source of truth) ---------
# CONNECTOR_STORE_REDIS_URL=redis://localhost:6379/0
# CONNECTOR_STORE_PG_HOST=localhost
# CONNECTOR_STORE_PG_PASSWORD=          # supply the DB password here, never in the manifest

# --- Access control (API-key / token auth) ----------------------------------
# ON by default (checks every request against Redis); set false to disable.
# ACCESS_CONTROL_ENABLE=false
# The ordered token-resolution chain, a JSON list; the first provider to recognize a
# credential wins. Defaults to '["redis"]'.
# ACCESS_CONTROL_AUTH_PROVIDERS='["redis"]'
# ACCESS_CONTROL_REDIS_URL=redis://localhost:6379/0
# Exact paths reachable by any AUTHENTICATED identity regardless of the route table
# (jq still applies); a JSON list. Defaults to '["/api/auth/me"]'.
# ACCESS_CONTROL_AUTHENTICATED_ALWAYS_ALLOWED_PATHS='["/api/auth/me"]'
# One-time claim link (QR onboarding): default TTL of the raw-key claim record, in
# seconds. A per-link ttl is capped at ACCESS_CONTROL_CLAIM_LINK_MAX_TTL_SECONDS (3600).
# ACCESS_CONTROL_CLAIM_LINK_TTL_SECONDS=600

# --- LLM / embedding providers (used by agents) -----------------------------
# LLM_PROVIDER_LLM=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=                          # provider API key (kept out of logs via SecretStr)
# EMBEDDING_API_KEY=
